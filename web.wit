package webidl:baseline;

// Curated subset of the full canonwit-generated `web` interface
// (see ~/src/webidl-index/baseline/baseline.wit for the complete output).
// The full interface (700+ resources, 1698 funcs) exceeds a wit-component
// 0.41 binary-encoding limit ("instance type declaration size is out of
// bounds"); this file keeps just the resources/functions the demos in
// this repo call, with their real canonwit signatures, plus whatever
// types those signatures transitively require.
//
// One deliberate deviation from the real signature: `document.body()`'s
// sibling `create-element` drops its optional `options` parameter. jco
// 1.25.2's zero-config WebIDL proxy crashes (`Cannot read properties of
// undefined (reading 'Symbol(isProxy)')`) when an `option<T>` argument
// lowers to JS `undefined`, which is exactly what we'd always pass here
// since none of the demos need element-creation options. Dropping the
// parameter avoids the crash entirely rather than working around a bug
// in a third-party tool. `node.first-child`/`next-sibling` return
// `option<node>` too, but only ever as a *return* value, which jco
// handles fine — the bug is specifically about `option<T>` arguments.
//
// Another simplification: `element.get-context2d` stands in for the real
// `HTMLCanvasElement.getContext("2d")`, which takes a context-type string
// and options and can return different resource types depending on it.
// The demos here only ever create canvases and only ever want a 2D
// context, so this drops the argument and fixes the return type instead
// of modeling the real overload.
//
// Similarly, `get-image-data`/`put-image-data` flatten the real
// `ImageData` object (a `{width, height, data}` bundle) into a plain
// `list<u8>` plus explicit width/height parameters, since the demos here
// only care about moving the raw pixel bytes across the boundary.
//
// `element.insert-before`'s real signature (`Node.insertBefore`) allows a
// null reference to mean "append at the end" — another `option<T>`
// argument that would hit the jco crash above. Here `reference` is
// mandatory; callers that want to append use `append-child` instead.

interface web {
  resource document {
    body: func() -> option<html-element>;
    create-element: func(local-name: string) -> element;
    create-text-node: func(data: string) -> text;
    get-element-by-id: func(element-id: string) -> option<element>;
    get-elements-by-class-name: func(class-name: string) -> list<element>;
  }
  resource dom-token-list {
    add: func(tokens: list<string>);
  }
  resource canvas-rendering-context2d {
    fill-rect: func(x: f64, y: f64, width: f64, height: f64);
    get-image-data: func(x: f64, y: f64, width: f64, height: f64) -> list<u8>;
    put-image-data: func(data: list<u8>, x: f64, y: f64, width: f64, height: f64);
    set-fill-style: func(value: string);
  }
  resource element {
    append-child: func(node: borrow<node>) -> node;
    class-list: func() -> dom-token-list;
    get-context2d: func() -> canvas-rendering-context2d;
    insert-before: func(node: borrow<node>, reference: borrow<node>) -> node;
    remove: func();
    set-attribute: func(qualified-name: string, value: trusted-type-or-string);
    set-attributes: func(pairs: list<tuple<string, string>>);
  }
  resource html-element {
    append-child: func(node: borrow<node>) -> node;
  }
  resource node {
    first-child: func() -> option<node>;
    next-sibling: func() -> option<node>;
    text-content: func() -> string;
    set-text-content: func(value: string);
  }
  resource text {
  }
  resource trusted-html {
  }
  variant trusted-html-or-trusted-script-or-trusted-script-url {
    trusted-html(trusted-html),
    trusted-script(trusted-script),
    trusted-script-url(trusted-script-url),
  }
  resource trusted-script {
  }
  resource trusted-script-url {
  }
  type trusted-type = trusted-html-or-trusted-script-or-trusted-script-url;
  variant trusted-type-or-string {
    trusted-type(trusted-type),
    %string(string),
  }
  resource window {
    document: func() -> document;
  }

  element-as-node: func(v: borrow<element>) -> node;
  get-window: func() -> window;
  now: func() -> f64;
  text-as-node: func(v: borrow<text>) -> node;
}
